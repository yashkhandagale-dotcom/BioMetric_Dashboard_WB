# Copy this file to .env (or .env.local) and set real values.
# Basic-auth credentials for the HR dashboard — required, no defaults.
# The app will reject every request if either is missing.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Leave Tracker — its OWN Supabase project, deliberately separate from the
# dashboard vars above (different URL, different keys, different DB). Run
# supabase-leave/schema.sql against this project, not the one above.
# Required for anything under /leave or /api/leave.
NEXT_PUBLIC_LEAVE_SUPABASE_URL=https://your-leave-project.supabase.co
NEXT_PUBLIC_LEAVE_SUPABASE_ANON_KEY=your-leave-anon-public-key
LEAVE_SUPABASE_SERVICE_ROLE_KEY=your-leave-service-role-key
