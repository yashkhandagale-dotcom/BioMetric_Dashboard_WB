# Copy this file to .env (or .env.local) and set real values.
#
# ── UNIFIED PROJECT ──────────────────────────────────────────────────────
# One Supabase project now backs both the Dashboard and the Leave Tracker
# (see unified_schema.sql). Both apps' Supabase client files read these
# same three vars — there is no separate "leave" URL/key set anymore.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
